# 复制为 application-local.yaml 并填入实际值（已加入 .gitignore）
spring:
  datasource:
    url: jdbc:postgresql://HOST:5432/miraagent
    username: YOUR_DB_USER
    password: YOUR_DB_PASSWORD

mira:
  model:
    api-key: YOUR_API_KEY
  weixin:
    enabled: false          # 设为 true 开启微信接入
    token: ${WEIXIN_BOT_TOKEN:}   # 已有 token 时跳过 QR 流程
    base-url: https://ilinkai.weixin.qq.com
